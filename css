* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Arial, sans-serif; 
}

body {
    background-color: rgb(167, 183, 223);
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
}

/* MUDANÇA AQUI: O contêiner agora é mais largo e coloca os filhos lado a lado */
#conteiner {
    background-color: white;
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    width: 100%;
    max-width: 950px; /* Aumentamos a largura máxima para caber as duas colunas */
    
    display: flex;
    flex-direction: row; /* Coloca Formulário do lado da Lista */
    gap: 40px; /* Espaço generoso entre as duas colunas */
    align-items: flex-start;
}

/* Coluna da Esquerda: Inputs e Cabeçalho */
.coluna-esquerda {
    flex: 1; /* Ocupa metade do espaço */
    display: flex;
    flex-direction: column;
}

h1 {
    color: #2c3e50;
    margin-bottom: 5px;
    font-size: 24px;
}

#saldo {
    color: #27ae60;
    margin-bottom: 20px;
    font-size: 20px;
}

.inputs {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.inputs input, #categoria, .inputs button {
    width: 100%;
    height: 45px;
    padding: 0 15px;
    font-size: 15px;
    border-radius: 25px;
    border: 1px solid #ccc;
    outline: none;
}

#categoria {
    cursor: pointer;
    background-color: #f9f9f9;
}

.inputs button {
    background-color: #3498db;
    color: white;
    font-weight: bold;
    border: none;
    cursor: pointer;
    transition: 0.2s;
}

.inputs button:hover {
    background-color: #2980b9;
}

#buscar {
    border: 1px dashed #3498db;
    background-color: #f0f7fc;
    margin-top: 10px;
}

/* Coluna da Direita: Lista de Gastos */
#lista {
    flex: 1.5; /* Ocupa um pouco mais de espaço que os inputs */
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    max-height: 500px; /* Limita a altura máxima da lista */
    overflow-y: auto; /* Se passar do limite, cria uma barra de rolagem sutil interna */
    padding-right: 5px;
}

